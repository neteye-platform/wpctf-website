[18.959495, "o", "\u001b(B\u001b[0;1m\u001b[31mf\u001b[39m\u001b(B\u001b[m \u001b[31mE\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m0\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m^\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[37m5\u001b[11;5H\u001b[31m \u001b[11;47H\u001b[37mO\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[37mA\u001b[11;75H9\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[37m4\u001b[12;17H\u001b[31m2\u001b[12;73H \u001b[13;17H\u001b[37m4\u001b[13;35H\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b[31me\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b[31mc\u001b[39m\u001b(B\u001b[m \u001b[31mW\u001b[14;21H\u001b(B\u001b[0;1m\u001b[31m \u001b[29Gf\u001b[37G\u001b[37m+\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b[31mO\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[37mX\u001b[15;29HQ\u001b[39m\u001b(B\u001b[m \u001b[31m]\u001b[39m\u001b(B\u001b[m \u001b[31mg\u001b[16;27H\u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31mV\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[37m=\r\u001b[17d\u001b(B\u001b[0m\u001b[31mm\t\u001b(B\u001b[0;1m\u001b[31m \u001b[17;61H,\r\u001b[18d\u001b[37mY\u001b[18;11H\u001b[31m \u001b[18;53H \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31mz\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[37m%\u001b[19;31H\u001b(B\u001b[0m\u001b[31m)\u001b[19;71Ho\u001b[20;19H\u001b(B\u001b[0;1m\u001b[31mB\u001b[20;31H\u001b[37mN\u001b[20;61H\u001b[31m \u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m>\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m8\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[31m \u001b[39m\u001b(B\u001b[m \u00